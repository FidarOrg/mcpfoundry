[project]
name = "{{projectName}}"
version = "0.1.0"
description = "MCP server generated by mcp-forge."
requires-python = ">=3.10"
dependencies = [
  "fastmcp>=2.0.0",
  "pydantic>=2.0.0",
{{#if secure}}
  "pyjwt>=2.8.0",
{{/if}}
{{#if isDatabase}}
  "psycopg[binary]>=3.1.0",
{{/if}}
]

[project.scripts]
{{projectName}} = "server:main"

[build-system]
requires = ["setuptools>=61"]
build-backend = "setuptools.build_meta"

[tool.setuptools]
py-modules = ["server"]
